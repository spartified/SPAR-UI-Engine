{
    "title": "Roles & Permissions",
    "endpoint": "/api/orion/roles",
    "permission": "orion:role:manage",
    "dbPool": "ORION",
    "tableName": "roles",
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "number",
            "primary": true,
            "hidden": true,
            "editable": false
        },
        {
            "name": "name",
            "label": "Role Name",
            "type": "text",
            "required": true,
            "editable": true
        },
        {
            "name": "description",
            "label": "Description",
            "type": "text",
            "required": false,
            "editable": true
        },
        {
            "name": "account_id",
            "label": "Account",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, name AS label FROM accounts WHERE status = 'ACTIVE'"
            },
            "required": true,
            "editable": true
        }
    ]
}