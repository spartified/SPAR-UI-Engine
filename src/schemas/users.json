{
    "module": "User Management",
    "endpoint": "/api/users",
    "permission": "user:manage",
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "text",
            "primary": true,
            "hidden": true,
            "editable": false
        },
        {
            "name": "username",
            "label": "Username",
            "type": "text",
            "required": true,
            "editable": false
        },
        {
            "name": "name",
            "label": "Full Name",
            "type": "text",
            "required": true,
            "editable": true
        },
        {
            "name": "email",
            "label": "Email",
            "type": "email",
            "primary": true,
            "required": true,
            "editable": true
        },
        {
            "name": "role",
            "label": "System Role",
            "type": "select",
            "options": [
                {
                    "label": "Admin",
                    "value": "admin"
                },
                {
                    "label": "Viewer",
                    "value": "viewer"
                }
            ],
            "required": true,
            "editable": true
        },
        {
            "name": "tenants",
            "label": "Allowed Tenants",
            "type": "multi-select",
            "lookup": {
                "dbPool": "CORE",
                "query": "SELECT id AS value, name AS label FROM tenants"
            },
            "required": true,
            "editable": true,
            "hidden": false,
            "showInList": true
        },
        {
            "name": "permissions",
            "label": "Granular Permissions",
            "type": "multi-select",
            "lookup": {
                "dbPool": "SYSTEM",
                "query": "available_permissions"
            },
            "required": false,
            "editable": true,
            "hidden": false,
            "showInList": true
        }
    ]
}