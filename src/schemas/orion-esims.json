{
    "title": "SIM Management",
    "endpoint": "/api/orion/esims",
    "permission": "orion:esim:manage",
    "permissions": {
        "create": "disabled",
        "delete": "disabled",
        "update": "orion:esim:manage"
    },
    "dbPool": "ORION",
    "tableName": "esims",
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "number",
            "primary": true,
            "hidden": true,
            "editable": false
        },
        {
            "name": "iccid",
            "label": "ICCID",
            "type": "text",
            "required": true,
            "editable": false,
            "linkUrl": "/esims-details?iccid={iccid}"
        },
        {
            "name": "mapped_imsi",
            "label": "Mapped IMSI",
            "type": "text",
            "required": false,
            "editable": true
        },
        {
            "name": "batch_id",
            "label": "Inventory ID",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, inventory_id AS label FROM inventory_batches"
            },
            "required": false,
            "editable": true
        },
        {
            "name": "account_id",
            "label": "Account",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, name AS label FROM accounts WHERE status = 'ACTIVE'"
            },
            "showInList": true,
            "required": false,
            "editable": true
        },
        {
            "name": "package_id",
            "label": "Package",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, name AS label FROM package_templates"
            },
            "showInList": true,
            "required": false,
            "editable": true
        },
        {
            "name": "status",
            "label": "Status",
            "type": "select",
            "options": [
                {
                    "label": "Available",
                    "value": "AVAILABLE"
                },
                {
                    "label": "Allocated",
                    "value": "ALLOCATED"
                },
                {
                    "label": "Activated",
                    "value": "ACTIVATED"
                },
                {
                    "label": "Suspended",
                    "value": "SUSPENDED"
                },
                {
                    "label": "Deactivated",
                    "value": "DEACTIVATED"
                }
            ],
            "required": true,
            "editable": true
        }
    ]
}