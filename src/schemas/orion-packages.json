{
    "title": "Package Management",
    "endpoint": "/api/orion/packages",
    "permission": "orion:package:manage",
    "dbPool": "ORION",
    "tableName": "package_templates",
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "number",
            "primary": true,
            "hidden": true,
            "editable": false
        },
        {
            "name": "remote_id",
            "label": "Remote ID",
            "type": "text",
            "editable": false
        },
        {
            "name": "account_id",
            "label": "Account",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, name AS label FROM accounts WHERE status = 'ACTIVE'"
            },
            "required": true,
            "editable": true
        },
        {
            "name": "account_name",
            "label": "Account",
            "type": "text",
            "editable": false
        },
        {
            "name": "earliest_available_date",
            "label": "Earliest Availability",
            "type": "date",
            "editable": true
        },
        {
            "name": "latest_available_date",
            "label": "Latest Availability",
            "type": "date",
            "editable": true
        },
        {
            "name": "name",
            "label": "Package Name",
            "type": "text",
            "required": true,
            "editable": true
        },
        {
            "name": "data_limit_mb",
            "label": "Data Limit (MB)",
            "type": "number",
            "required": true,
            "editable": true
        },
        {
            "name": "duration_seconds",
            "label": "Duration (Sec)",
            "type": "number",
            "required": true,
            "editable": true
        },
        {
            "name": "sync_status",
            "label": "Sync Status",
            "type": "select",
            "options": [
                {
                    "label": "In Sync",
                    "value": "IN_SYNC"
                },
                {
                    "label": "Out of Sync",
                    "value": "OUT_OF_SYNC"
                },
                {
                    "label": "Failed",
                    "value": "FAILED"
                }
            ],
            "editable": false
        },
        {
            "name": "status",
            "label": "Status",
            "type": "select",
            "options": [
                {
                    "label": "Active",
                    "value": "ACTIVE"
                },
                {
                    "label": "Inactive",
                    "value": "INACTIVE"
                }
            ],
            "editable": true
        },
        {
            "name": "traffic_policy",
            "label": "Traffic Policy ID",
            "type": "number",
            "default": 1053,
            "required": true,
            "editable": true
        }
    ]
}