{
    "title": "Account Management",
    "endpoint": "/api/orion/accounts",
    "permission": "orion:account:manage",
    "dbPool": "ORION",
    "tableName": "accounts",
    "metadataConfig": {
        "deleteType": "soft",
        "updatedAtField": "updated_at",
        "lastActionField": "status",
        "softDeleteValue": "DELETED",
        "listFilter": "status != 'DELETED'"
    },
    "fields": [
        {
            "name": "id",
            "label": "ID",
            "type": "number",
            "primary": true,
            "hidden": true,
            "editable": false
        },
        {
            "name": "name",
            "label": "Account Name",
            "type": "text",
            "required": true,
            "editable": true
        },
        {
            "name": "parent_id",
            "label": "Parent Account",
            "type": "select",
            "lookup": {
                "dbPool": "ORION",
                "query": "SELECT id AS value, name AS label FROM accounts WHERE status = 'ACTIVE'"
            },
            "required": false,
            "editable": true
        },
        {
            "name": "type",
            "label": "Account Type",
            "type": "select",
            "options": [
                {
                    "label": "Root",
                    "value": "ROOT"
                },
                {
                    "label": "Enterprise",
                    "value": "ENTERPRISE"
                },
                {
                    "label": "Reseller",
                    "value": "RESELLER"
                },
                {
                    "label": "Customer",
                    "value": "CUSTOMER"
                }
            ],
            "required": true,
            "editable": true
        },
        {
            "name": "state",
            "label": "State",
            "type": "select",
            "options": [
                {
                    "label": "Trial",
                    "value": "TRIAL"
                },
                {
                    "label": "Production",
                    "value": "PRODUCTION"
                }
            ],
            "required": false,
            "editable": true
        },
        {
            "name": "billing_enabled",
            "label": "Billing Enabled",
            "type": "checkbox",
            "required": false,
            "editable": true
        },
        {
            "name": "classifier",
            "label": "Classifier",
            "type": "select",
            "options": [
                {
                    "label": "TravelSIM",
                    "value": "TRAVELSIM"
                },
                {
                    "label": "IoT",
                    "value": "IOT"
                },
                {
                    "label": "CAMARA",
                    "value": "CAMARA"
                }
            ],
            "required": false,
            "editable": true
        },
        {
            "name": "contact_first_name",
            "label": "Contact First Name",
            "type": "text",
            "required": false,
            "editable": true
        },
        {
            "name": "contact_last_name",
            "label": "Contact Last Name",
            "type": "text",
            "required": false,
            "editable": true
        },
        {
            "name": "contact_email",
            "label": "Contact Email",
            "type": "email",
            "required": false,
            "editable": true
        },
        {
            "name": "contact_phone",
            "label": "Contact Phone",
            "type": "text",
            "required": false,
            "editable": true
        },
        {
            "name": "markup_percentage",
            "label": "Markup %",
            "type": "number",
            "required": false,
            "editable": true
        },
        {
            "name": "status",
            "label": "Status",
            "type": "select",
            "options": [
                {
                    "label": "Active",
                    "value": "ACTIVE"
                },
                {
                    "label": "Inactive",
                    "value": "INACTIVE"
                }
            ],
            "required": true,
            "editable": true
        }
    ]
}