{
    "title": "Orion Dashboard",
    "filters": [
        {
            "key": "dateRange",
            "type": "dateRange",
            "label": "Date Range",
            "defaultValue": "yesterday"
        }
    ],
    "rows": [
        {
            "gutter": 16,
            "columns": [
                {
                    "span": 6,
                    "widget": {
                        "type": "statistic",
                        "title": "Total Accounts",
                        "prefixIcon": "TeamOutlined",
                        "color": "#3C83F6",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT COUNT(*) AS value FROM accounts WHERE status = 'ACTIVE'"
                        }
                    }
                },
                {
                    "span": 6,
                    "widget": {
                        "type": "statistic",
                        "title": "Total eSIMs",
                        "prefixIcon": "MobileOutlined",
                        "color": "#22D3EE",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT COUNT(*) AS value FROM esims"
                        }
                    }
                },
                {
                    "span": 6,
                    "widget": {
                        "type": "statistic",
                        "title": "Active eSIMs",
                        "prefixIcon": "CheckCircleOutlined",
                        "color": "#3f8600",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT COUNT(*) AS value FROM esims WHERE status = 'ACTIVATED'"
                        }
                    }
                },
                {
                    "span": 6,
                    "widget": {
                        "type": "statistic",
                        "title": "Inventory Batches",
                        "prefixIcon": "DatabaseOutlined",
                        "color": "#faad14",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT COUNT(*) AS value FROM inventory_batches"
                        }
                    }
                }
            ]
        },
        {
            "gutter": 16,
            "columns": [
                {
                    "span": 12,
                    "widget": {
                        "type": "chart",
                        "title": "eSIM Status Distribution",
                        "chartType": "pie",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT status AS name, COUNT(*) AS value FROM esims GROUP BY status"
                        }
                    }
                },
                {
                    "span": 12,
                    "widget": {
                        "type": "chart",
                        "title": "Accounts by Type",
                        "chartType": "bar",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT type AS name, COUNT(*) AS value FROM accounts WHERE status = 'ACTIVE' GROUP BY type"
                        }
                    }
                }
            ]
        },
        {
            "gutter": 16,
            "columns": [
                {
                    "span": 24,
                    "widget": {
                        "type": "chart",
                        "title": "eSIMs by Account Names",
                        "chartType": "bar",
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT accounts.name AS x_axis, stats.total AS total_esims, stats.active AS active_esims FROM accounts LEFT JOIN (SELECT account_id, COUNT(*) AS total, SUM(CASE WHEN status = 'ACTIVATED' THEN 1 ELSE 0 END) AS active FROM esims GROUP BY account_id) stats ON accounts.id = stats.account_id WHERE status = 'ACTIVE'"
                        }
                    }
                }
            ]
        },
        {
            "gutter": 16,
            "columns": [
                {
                    "span": 24,
                    "widget": {
                        "type": "table",
                        "title": "Recent Lifecycle Actions",
                        "columns": [
                            {
                                "title": "eSIM ID",
                                "dataIndex": "esim_id",
                                "key": "esim_id"
                            },
                            {
                                "title": "Action",
                                "dataIndex": "action",
                                "key": "action"
                            },
                            {
                                "title": "Status",
                                "dataIndex": "status",
                                "key": "status"
                            },
                            {
                                "title": "Timestamp",
                                "dataIndex": "created_at",
                                "key": "created_at"
                            }
                        ],
                        "dataSource": {
                            "dbPool": "ORION",
                            "query": "SELECT esim_id, action, status, created_at FROM esim_lifecycle_actions ORDER BY created_at DESC LIMIT 10"
                        }
                    }
                }
            ]
        }
    ]
}